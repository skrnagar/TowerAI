# =============================================================================
# TOWER AI SAFETY MONITORING SYSTEM — Environment Configuration
# Copy to .env and adjust values for your deployment
# =============================================================================

# --- General ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
API_V1_PREFIX=/api/v1

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=Tower AI Safety
NEXT_PUBLIC_SUPABASE_URL=https://edwdhyoghxnqrgzrocol.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# --- PostgreSQL (local Docker OR Supabase cloud) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=towerai
POSTGRES_PASSWORD=towerai_secure_password
POSTGRES_DB=towerai_db
DATABASE_URL=postgresql+asyncpg://towerai:towerai_secure_password@postgres:5432/towerai_db

# Supabase cloud (replace [YOUR-PASSWORD]) — use Session Pooler on IPv4 networks
# SUPABASE_PROJECT_REF=edwdhyoghxnqrgzrocol
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.edwdhyoghxnqrgzrocol.supabase.co:5432/postgres

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=towerai_minio
MINIO_SECRET_KEY=towerai_minio_secret
MINIO_BUCKET_VIOLATIONS=towerai-violations
MINIO_BUCKET_RECORDINGS=towerai-recordings
MINIO_USE_SSL=false

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Engine (Blueprint v2.0 — YOLOv8x primary) ---
AI_ENGINE_HOST=ai-engine
AI_ENGINE_PORT=8001
AI_INFERENCE_FPS=5
AI_STREAM_FPS=15
AI_GPU_ENABLED=true
AI_BATCH_SIZE=4
AI_ENSEMBLE_ENABLED=false
AI_POSE_ENABLED=false
YOLO_MODEL_PATH=/models/tower_safety/phase2_full/weights/best.pt
YOLO_ENSEMBLE_MODEL_PATH=/models/tower_safety/yolov9e_best.pt
TEMPORAL_FILTER_THRESHOLD=5
TEMPORAL_FILTER_WINDOW=15
VLM_VERIFIER_ENABLED=false
VLM_CONFIDENCE_TRIGGER=0.70

# --- Twilio WhatsApp Alerts (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_SUPERVISOR_PHONE=

# --- Camera / RTSP ---
RTSP_FRAME_BUFFER_SIZE=30
RTSP_RECONNECT_DELAY_SECONDS=5
RTSP_DEFAULT_FPS=15

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
